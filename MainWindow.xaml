<ui:FluentWindow
    x:Class="NSW.M2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:core="clr-namespace:NSW.Core.UI"
    xmlns:prop="clr-namespace:NSW.M2.Properties"
    mc:Ignorable="d"
    Title="{x:Static prop:Resources.Main_Title}"
    Width="960" Height="720"
    MinWidth="600" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    d:WindowBackdropType="None"
    WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#400078D4"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <DataTemplate x:Key="TypeCellTemplate">
            <Border CornerRadius="4" Padding="6,2"
                    Background="{Binding TypeBackground}"
                    HorizontalAlignment="Left">
                <TextBlock Text="{Binding FileType}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{Binding TypeForeground}"/>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar 
            Title="{Binding AppVersion, RelativeSource={RelativeSource AncestorType=Window}}"
            Height="36"
            FontSize="14" Grid.ColumnSpan="2" VerticalAlignment="Center">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/icon.ico"
                      Width="20" Height="20"
                      Margin="0,-2,0,0"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        
        <!-- Main -->
        <Grid Grid.Row="1" Margin="15,5,15,15">
            <Grid.RowDefinitions>
                <!-- 게임 파일 헤더 -->
                <RowDefinition Height="220"/>
                <!-- 파일 리스트 -->
                <RowDefinition Height="Auto"/>
                <!-- 출력 경로 -->
                <RowDefinition Height="Auto"/>
                <!-- 시작 버튼 -->
                <RowDefinition Height="Auto"/>
                <!-- 진행바 -->
                <RowDefinition Height="*"/>
                <!-- 로그 -->
            </Grid.RowDefinitions>

            <!-- 게임 파일 섹션 헤더 -->
            <Grid Grid.Row="0">
                <core:FileManagerControl x:Name="FileMgr" 
                              Grid.Row="0" 
                              Height="280" 
                              Margin="0,0,0,16"/>
            </Grid>

            <!-- 출력 경로 입력 -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Save24" Margin="0,0,8,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{x:Static prop:Resources.Label_OutputPath}"
                           FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,12,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="2" Margin="0,0,8,0"
                        Background="#12FFFFFF"
                        BorderBrush="#30FFFFFF"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <TextBox x:Name="txtOutput"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#DCDCDC"
                                 CaretBrush="#DCDCDC"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Height="36"/>
                        <TextBlock x:Name="outputHint"
                                   Text="{x:Static prop:Resources.Hint_SelectOutput}"                                   
                                   Foreground="#50FFFFFF"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <ui:Button Grid.Column="3"
                           x:Name="btnBrowseOutput"
                           Appearance="Secondary"
                           Width="36" Height="36"
                           Padding="0"
                           ToolTip="{x:Static prop:Resources.ToolTip_BrowseOutput}"
                           Click="BtnBrowseOutput_Click">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18"/>
                </ui:Button>
            </Grid>

            <!-- 시작 버튼 -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                           x:Name="btnMergeStart"
                           Content="{x:Static prop:Resources.Button_MergeStart}"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Center"
                           Height="44"
                           FontSize="12" FontWeight="SemiBold"
                           Click="BtnMergeStart_Click"/>

                <ui:Button Grid.Column="2"
                           x:Name="btnSplitStart"
                           Content="{x:Static prop:Resources.Button_SplitStart}"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Center"
                           Height="44"
                           FontSize="12" FontWeight="SemiBold"
                           Click="BtnSplitStart_Click"/>
            </Grid>

            <!-- 진행바 -->
            <Grid Grid.Row="3" Margin="0,0,0,10"
                  x:Name="progressArea"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="progressLabel"
                               Grid.Column="0" 
                               Text="{x:Static prop:Resources.Status_Processing}"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="progressTime"
                               Grid.Column="1"
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </Grid>
                <ProgressBar Grid.Row="1"
                             x:Name="progress"
                             Minimum="0" Maximum="100"
                             Height="4"/>
            </Grid>

            <!-- 로그 -->
            <Border Grid.Row="4"
                    Background="#12FFFFFF"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="2">
                <RichTextBox x:Name="logBox"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="#C8C8C8"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8,6"/>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
