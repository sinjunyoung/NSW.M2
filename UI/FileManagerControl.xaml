<UserControl x:Class="NSW.Core.UI.FileManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        
        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBorder" 
                            Background="#1AFFFFFF" 
                            BorderBrush="#30FFFFFF" 
                            BorderThickness="0,0,1,1" 
                            Padding="8,5">

                                <TextBlock Text="{TemplateBinding Content}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A0A0A0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=GridViewColumnHeader}}" Value="False">
                                                    <Setter Property="Foreground" Value="#60FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ListItemBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,1"
                        Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ListItemBorder" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1AFFFFFF"/>
                    <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TypeCellTemplate">
            <Border CornerRadius="4" Padding="6,2"
                Background="{Binding TypeBackground}"
                HorizontalAlignment="Left">
                <TextBlock Text="{Binding FileType}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{Binding TypeForeground}"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border BorderBrush="#33FFFFFF" 
            BorderThickness="1" 
            CornerRadius="8" 
            Background="#12FFFFFF" 
            Padding="10">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel x:Name="dropHint"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Opacity="0.4"
                        IsHitTestVisible="False"
                        Panel.ZIndex="1">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="30" Margin="0,0,0,10"/>
                    <TextBlock Text="NSP, NSZ, XCI, XCZ 파일을 드래그&amp;드롭하세요" 
                           FontSize="11" 
                           HorizontalAlignment="Center"/>
                </StackPanel>

                <ListView x:Name="lvFiles" 
                          Background="Transparent" 
                          BorderThickness="0" 
                          Foreground="#DCDCDC"
                          AllowDrop="True" 
                          DragEnter="LvFiles_DragEnter" 
                          Drop="LvFiles_Drop"
                          KeyUp="LvFiles_KeyUp"
                          SelectionMode="Extended">
                    <ListView.View>
                        <GridView>                            
                            <GridViewColumn Header="종류" Width="80" CellTemplate="{StaticResource TypeCellTemplate}"/>
                            <GridViewColumn Header="파일명" Width="260">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="경로" Width="420">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FilePath}" FontSize="11" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                <ui:Button x:Name="btnAddFile" Width="36" Height="36" Margin="0,0,0,8" 
                           Padding="0" 
                           Appearance="Secondary"
                           BorderThickness="1"
                           CornerRadius="6"
                           ToolTip="파일 추가"
                           Click="BtnAddFile_Click">
                    <ui:SymbolIcon Symbol="FolderAdd24" FontSize="18"/>
                </ui:Button>

                <ui:Button x:Name="btnRemoveFile" Width="36" Height="36" Margin="0,0,0,8" 
                           Padding="0" 
                           Appearance="Secondary"
                           BorderThickness="1"
                           CornerRadius="6"
                           ToolTip="선택 항목 제거"
                           Click="BtnRemoveFile_Click">
                    <ui:SymbolIcon Symbol="Delete24" FontSize="18"/>
                </ui:Button>

                <ui:Button x:Name="btnRemoveAllFiles" Width="36" Height="36" 
                           Padding="0" 
                           Appearance="Secondary"
                           BorderThickness="1"
                           CornerRadius="6"
                           ToolTip="전체 항목 제거"
                           Click="BtnRemoveAllFiles_Click">
                    <ui:SymbolIcon Symbol="DeleteOff24" FontSize="18"/>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>